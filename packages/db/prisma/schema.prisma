// FlipFlow Prisma schema
//
// Models:
//   - User / Account / Session / VerificationToken: NextAuth v5 adapter
//   - Category: a deck of flashcards owned by a user
//   - Flashcard: front/back card with SM-2 spaced-repetition fields

generator client {
  provider      = "prisma-client-js"
  // Include the Vercel/Lambda Linux engine alongside the local native engine.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// NextAuth (Auth.js) models
// ----------------------------------------------------------------------------

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  categories    Category[]
  flashcards    Flashcard[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------------
// Domain models
// ----------------------------------------------------------------------------

model Category {
  id        String      @id @default(cuid())
  name      String
  color     String?
  // BCP-47 language tag for the back of cards in this deck (e.g. "fr-FR",
  // "es-ES", "ja-JP"). Drives the Google Cloud Text-to-Speech voice when
  // the user clicks the audio button on the back of a card. Null means no
  // language has been configured yet — the audio button is hidden.
  backLanguage String?
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards     Flashcard[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model Flashcard {
  id         String    @id @default(cuid())
  front      String    @db.Text
  back       String    @db.Text
  // Example sentences for the front and back of the card (optional, defaults
  // to empty array). Stored as a Postgres text array.
  frontExamples String[] @map("front_examples")
  backExamples  String[] @map("back_examples")
  // Optional part-of-speech ("class") for the front word — e.g. "noun",
  // "verb", "adjective". Free-form string so we don't have to migrate the
  // schema every time we tweak the list of options shown in the UI.
  class      String?
  // Optional. Cards can live outside of a deck — they show up only in the
  // "All decks" view. When the deck is deleted, the card cascades with it.
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  // Direct ownership pointer so we can find a user's uncategorized cards
  // (where categoryId is null) without joining through Category.
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // SM-2 spaced-repetition state
  confidence  Int       @default(0) // last rating, 0-5
  easeFactor  Float     @default(2.5)
  interval    Int       @default(0) // days until next review
  repetitions Int       @default(0) // successful reviews in a row
  nextReview  DateTime? // null = brand new, never reviewed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([categoryId, nextReview])
  @@index([userId])
  @@index([userId, nextReview])
}
